generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HabitType {
  boolean
  integer
  decimal
  score
  time
  duration
  duration_hours
  multi_boolean
  text
}

// Sibling apps that can auto-complete a habit. A habit with a source is a
// boolean habit whose entries are written by that app via /api/integrations,
// not by the user tapping a checkbox.
enum HabitSource {
  fitness_workout
  journal_entry
}

enum HabitScheduleKind {
  daily
  weekdays
  weekly_count
  interval
}

enum GoalDirection {
  at_least
  at_most
}

enum TokenType {
  email_verification
  password_reset
}

enum UserRole {
  user
  admin
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  emailVerified Boolean   @default(false) @map("email_verified")
  isGuest       Boolean   @default(false) @map("is_guest")
  role          UserRole  @default(user)
  // Null = active; a timestamp marks the account as suspended (and when).
  disabledAt    DateTime? @map("disabled_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  sessions Session[]
  tokens   VerificationToken[]
  groups   HabitGroup[]
  habits   Habit[]
  entries  Entry[]

  // Lets the guest-cleanup job efficiently find expired guest accounts.
  @@index([isGuest, createdAt])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  userAgent String?  @map("user_agent")
  ip        String?
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  type      TokenType
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("verification_tokens")
}

model HabitGroup {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  color     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habits    Habit[]

  @@index([userId])
  @@map("habit_groups")
}

model Habit {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  name        String
  description String?
  type        HabitType
  unit        String?
  min         Decimal?  @db.Decimal(12, 4)
  max         Decimal?  @db.Decimal(12, 4)
  sortOrder   Int       @default(0) @map("sort_order")
  archived    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  groupId     String?   @map("group_id") @db.Uuid

  // Null = a normal, manually tracked habit. Set = auto-completed by a sibling
  // app (fitnessmaxxing / journalmaxxing); always boolean-typed.
  source HabitSource?

  // Scheduling: when is this habit "due"? Defaults to every day so habits that
  // predate this feature keep their existing behaviour. See server/src/schedule.ts.
  scheduleKind   HabitScheduleKind @default(daily) @map("schedule_kind")
  scheduleDays   Int[]             @default([]) @map("schedule_days") // ISO weekdays 1..7 (Mon..Sun), for `weekdays`
  scheduleTarget Int?              @map("schedule_target") // times per week, for `weekly_count`
  scheduleEvery  Int?              @map("schedule_every") // every N days, for `interval`
  scheduleAnchor DateTime?         @map("schedule_anchor") @db.Date // anchor/start date, for `interval`

  // Goal: the numeric target that defines "done" for this habit. Null means the
  // habit has no goal, so any logged entry counts as done (pre-feature behaviour).
  // Only meaningful for numeric types (integer/decimal/score/duration); boolean
  // habits are "done" when checked and time/text habits when an entry exists.
  goalTarget    Decimal?      @map("goal_target") @db.Decimal(12, 4)
  goalDirection GoalDirection @default(at_least) @map("goal_direction") // at_least: hit >= target; at_most: stay <= target
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  group         HabitGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  entries       Entry[]

  @@index([userId])
  @@index([groupId])
  @@map("habits")
}

model Entry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  habitId   String   @map("habit_id") @db.Uuid
  entryDate DateTime @map("entry_date") @db.Date
  valueBool Boolean? @map("value_bool")
  valueNum  Decimal? @map("value_num") @db.Decimal(12, 4)
  valueText String?  @map("value_text")
  valueTime String?  @map("value_time")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, entryDate])
  @@index([userId])
  @@index([entryDate])
  @@map("entries")
}
